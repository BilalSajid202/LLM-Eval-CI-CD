# LLM pipeline & judges
ANTHROPIC_API_KEY=sk-ant-...

# Storage
DATABASE_URL=postgresql://user:pass@localhost:5432/llm_eval
S3_BUCKET=llm-eval-outputs
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Local fallback when S3 is not configured
LOCAL_STORAGE_PATH=./.eval-storage

# GitHub merge gate
GITHUB_TOKEN=ghp_...
GITHUB_REPOSITORY=org/llm-eval-pipeline
DASHBOARD_URL=http://localhost:3000

# Modal (optional — enables parallel serverless workers)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Alerts (optional)
SLACK_WEBHOOK_URL=

# Runtime
EVAL_MODE=local
LOG_LEVEL=INFO
